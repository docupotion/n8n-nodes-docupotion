{
  "name": "n8n-nodes-docupotion",
  "version": "0.1.2",
  "description": "n8n community node to generate PDF documents with DocuPotion",
  "license": "MIT",
  "homepage": "https://docupotion.com",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Alex Cooney",
    "email": "alex@docupotion.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/docupotion/n8n-nodes-docupotion.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/DocupotionApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Docupotion/Docupotion.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
